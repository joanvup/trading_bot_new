# ============================================================
# TRADING BOT - Variables de Entorno
# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas el .env real a git
# ============================================================

# ---- MODO DE OPERACIÓN ----
# Opciones: testnet | dry_run | live
# testnet  → usa la API real de testnet de Binance (sin dinero real)
# dry_run  → simula órdenes localmente sin conectar a ningún exchange
# live     → opera con dinero real (¡usar con precaución!)
TRADING_MODE=testnet

# ---- BINANCE API ----
# Testnet (https://testnet.binancefuture.com)
BINANCE_TESTNET_API_KEY=TU_API_KEY_TESTNET
BINANCE_TESTNET_API_SECRET=TU_API_SECRET_TESTNET

# Live (https://www.binance.com) - solo si TRADING_MODE=live
BINANCE_LIVE_API_KEY=TU_API_KEY_LIVE
BINANCE_LIVE_API_SECRET=TU_API_SECRET_LIVE

# ---- BASE DE DATOS POSTGRESQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_POSTGRES

# ---- CONFIGURACIÓN DE TRADING ----
# Capital inicial disponible en USDT
INITIAL_CAPITAL=1000.0

# Riesgo máximo por operación (% del capital)
MAX_RISK_PER_TRADE=0.02

# Drawdown máximo permitido (% del capital pico)
MAX_DRAWDOWN=0.15

# Número máximo de posiciones simultáneas
MAX_OPEN_POSITIONS=3

# Apalancamiento máximo permitido
MAX_LEVERAGE=5

# ── SL / TP / Trailing Stop ────────────────────
SL_ATR_MULTIPLIER=1.5
TP_ATR_MULTIPLIER=3.0
MIN_RISK_REWARD=1.5
MIN_SL_PCT=0.003
MAX_SL_PCT=0.05
TRAIL_ATR_MULTIPLIER=1.2
TRAIL_ACTIVATION_ATR=0.5   # El TS se activa cuando el precio se mueve 0.5x ATR a favor
BREAKEVEN_ATR=1.0          # El SL va al breakeven cuando el precio se mueve 1.0x ATR a favor
TRAIL_ATR_MULTIPLIER=1.2   # El TS se mantiene a 1.2x ATR del precio actual

# ---- SELECCIÓN DE ACTIVOS ----
# Número de criptos a analizar simultáneamente
TOP_SYMBOLS_COUNT=20

# Intervalo de análisis principal (1m, 3m, 5m, 15m, 1h, 4h)
PRIMARY_TIMEFRAME=15m

# Intervalo secundario para confirmación de tendencia
SECONDARY_TIMEFRAME=1h

# ---- LOGGING ----
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ---- API REST (FASTAPI) ----
API_HOST=127.0.0.1
API_PORT=8000
API_SECRET_KEY=cambia-este-secret-key-en-produccion

# ---- ALERTAS (opcional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- MODELOS IA ----
# Directorio donde se guardan los modelos entrenados
MODELS_DIR=models/saved
# Reentrenamiento automático cada N horas
RETRAIN_INTERVAL_HOURS=24
